@using System.Web.Http
@using System.Web.Http.Controllers
@using System.Web.Http.Description
@using EDDY.IS.Vendor.Web.API.Areas.HelpPage
@using EDDY.IS.Vendor.Web.API.Areas.HelpPage.Models
@model IGrouping<HttpControllerDescriptor, ApiDescription>

@{
    var controllerDocumentation = ViewBag.DocumentationProvider != null ?
        ViewBag.DocumentationProvider.GetDocumentation(Model.Key) :
        null;
}

<h2 id="@Model.Key.ControllerName">@Model.Key.ControllerName</h2>
@if (!String.IsNullOrEmpty(controllerDocumentation))
{
    <p>@controllerDocumentation</p>
}
<table class="help-page-table">
    <thead>
        <tr><th>Method</th><th>API</th><th>Description</th></tr>
    </thead>
    <tbody>
        @foreach (var api in Model.OrderBy(m => m.ActionDescriptor.ActionName))
        {
            if (api.RelativePath.IndexOf(api.ActionDescriptor.ActionName) > 0)
            {
                <tr>
                    <td >@api.HttpMethod</td>
                    <td class="api-name">

                        <a name="@api.GetRoutePath()" href="@Url.Action("Api", "Help", new { apiId = api.GetFriendlyId() })">@api.GetRoutePath()</a>
                        @foreach (var parameterDescription in api.ParameterDescriptions.OrderBy(m => m.Name))
                    {
                        if (parameterDescription != null)
                        {
                                <p>@ViewBag.DocumentationProvider.GetDocumentation(parameterDescription.ParameterDescriptor)</p>
                            }
                            else
                            {
                                <p>No documentation available.</p>
                            }
                        }
                    </td>
                    <td class="api-documentation">
                        @if (api.Documentation != null)
                    {
                            <p>@api.Documentation</p>
                        }
                        else
                        {
                            <p>No documentation available.</p>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>