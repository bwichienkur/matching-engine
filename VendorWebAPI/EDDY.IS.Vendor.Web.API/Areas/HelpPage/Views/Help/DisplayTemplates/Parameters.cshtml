@using System.Collections.Generic
@using System.Collections.ObjectModel
@using System.Web.Http.Description
@using System.Threading
@using EDDY.IS.Vendor.Web.API.Areas.HelpPage.ModelDescriptions
@model IList<ParameterDescription>

@{
    var rawUrl = Request.RawUrl != null ? Request.RawUrl.ToLower() : "";
    var useRawHtml = rawUrl.Contains("lead-update") || rawUrl.Contains("lead-save");}

@if (Model.Count > 0)
{
    <table class="help-page-table">
        <thead>
            <tr><th>Name</th><th>Description</th><th>Type</th></tr>
        </thead>
        <tbody>
            @foreach (ParameterDescription parameter in Model.OrderBy(m => m.Name))
            {
                ModelDescription modelDescription = parameter.TypeDescription;

                <tr>
                    <td class="parameter-name">@parameter.Name</td>
                    <td class="parameter-documentation">
                        @if (useRawHtml)
                        {
                            <p>@Html.Raw(parameter.Documentation)</p>
                        }
                        else
                        {
                            <p>@parameter.Documentation</p>
                        }
                    </td>
                    <td class="parameter-type">
                        @Html.DisplayFor(m => modelDescription.ModelType, "ModelDescriptionLink", new { modelDescription = modelDescription })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>None.</p>
}