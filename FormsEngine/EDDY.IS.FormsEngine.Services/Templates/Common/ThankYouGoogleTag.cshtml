@inherits System.Web.Mvc.WebViewPage<List<int>>

@if (Model.Count > 0)
{
    <script type="text/javascript">
    var unique = 1;
            @foreach (var ProgramId in Model)
            {
                <text>
                    fe_googleTagEvent('gaEvent' + unique.toString(), 'client', 'cross-sell', @ProgramId);
                    unique++;
                </text>
            }
    </script>
}
