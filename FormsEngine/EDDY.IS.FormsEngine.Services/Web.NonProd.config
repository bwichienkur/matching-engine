    </client>
  </system.serviceModel>


  <!-- ===================== -->
  <!-- Connection Strings Replace -->
  <!-- ===================== -->
  <connectionStrings>

    <add name="FEEntitiesContainer"
         connectionString="metadata=res://*/DataModel.FEModel.csdl|res://*/DataModel.FEModel.ssdl|res://*/DataModel.FEModel.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=PROJECT_NAME-sql1;initial catalog=Nexus;integrated security=True;multipleactiveresultsets=True;application name=EntityFramework&quot;"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />

    <add name="Nexus_Validation_Entities"
         connectionString="metadata=res://*/DataModel.VEModel.csdl|res://*/DataModel.VEModel.ssdl|res://*/DataModel.VEModel.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=PROJECT_NAME-sql1;initial catalog=Nexus;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />

    <add name="Nexus_Lead_Entities"
         connectionString="metadata=res://*/DataModel.LEModel.csdl|res://*/DataModel.LEModel.ssdl|res://*/DataModel.LEModel.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=PROJECT_NAME-sql1;initial catalog=Nexus;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />

    <add name="EddyLoggingEntities"
         connectionString="metadata=res://*/DataModel.DataMappings.csdl|res://*/DataModel.DataMappings.ssdl|res://*/DataModel.DataMappings.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=PROJECT_NAME-sql1;initial catalog=EddyLogging;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />

  </connectionStrings>

  <system.web>
