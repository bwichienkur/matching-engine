<?xml version="1.0" encoding="utf-8"?>

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">

  <system.serviceModel>
    <client>

      <endpoint name="BasicHttpBinding_IMatchingService"
                address="http://PROJECT_NAME-issvc1/EDDY.IS.MatchingEngine.Service/MatchingService.svc"
                xdt:Transform="SetAttributes"
