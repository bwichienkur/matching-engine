<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false"/>
    
  </configSections>
  <appSettings>
    <add key="CacheTemplatesTimeMinutes" value="1440"/>
    <add key="CacheTemplateMappingsTimeMinutes" value="120"/>
    <add key="EmailValidationLevel" value="3"/>
    <add key="CacheTemplatesEnabled" value="True"/>
    <add key="CacheTemplatesTimeMinutes" value="120"/>
    <add key="ClientSettingsProvider.ServiceUri" value=""/>
    <add key="CacheResourceMetaDatasTimeMinutes" value="5"/>
    <add key="CacheEMSTCPAMessagesTimeMinutes" value="120"/>
    <add key="CacheCampaignApplicationIdsTimeMinutes" value="120"/>
  </appSettings>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.LocalDbConnectionFactory, EntityFramework">
      <parameters>
        <parameter value="v11.0"/>
      </parameters>
    </defaultConnectionFactory>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer"/>
    </providers>
  </entityFramework>
  <connectionStrings><add name="FEEntitiesContainer" connectionString="metadata=res://*/DataModel.FEModel.csdl|res://*/DataModel.FEModel.ssdl|res://*/DataModel.FEModel.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=fe-sql1;initial catalog=Nexus;integrated security=True;multipleactiveresultsets=True;application name=EntityFramework&quot;" providerName="System.Data.EntityClient"/><add name="EMSEntities" connectionString="metadata=res://*/DataModel.EMSEntities.csdl|res://*/DataModel.EMSEntities.ssdl|res://*/DataModel.EMSEntities.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=qsqapl1-sql1;initial catalog=EMS;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient"/></connectionStrings>
  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding_IService" />
        <binding name="BasicHttpBinding_IService1" />
        <binding name="basicHttpEndPoint" />
        <binding name="BasicHttpBinding_ILeadScoringService" />
        <binding name="BasicHttpBinding_IMatchingService" />
        <binding name="BasicHttpBinding_IService2" />
        <binding name="BasicHttpBinding_IValidationService" />
