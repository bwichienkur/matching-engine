      <netTcpBinding>
        <binding name="netTcpEndPoint">
          <security mode="None">
            <transport sslProtocols="None" />
          </security>
        </binding>
      </netTcpBinding>
    </bindings>
    <client>
      <endpoint address="http://nexprodws01/Eddy.IS.PixelService/v3/Service.svc"
